rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{vendorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "aboodvv20@gmail.com";
    }
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "aboodvv20@gmail.com";
    }
  }
}
